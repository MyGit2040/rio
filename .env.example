APP_NAME=Eagle
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Evolution API engine (the WhatsApp "postman"). Leave blank until you have one.
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INTEGRATION=WHATSAPP-BAILEYS
EVOLUTION_WEBHOOK_SECRET=

# whatsapp-web.js bridge engine (selectable per tenant, runs alongside Evolution).
# WEBJS_API_KEY must match the bridge container's WEBJS_API_KEY.
# The bridge posts inbound events to the SAME webhook, so it reuses EVOLUTION_WEBHOOK_SECRET.
WEBJS_BASE_URL=
WEBJS_API_KEY=
WEBJS_FLAT_DELAY=60

# AI provider for the chatbot (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EVOLUTION_FLAT_DELAY=60

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5
