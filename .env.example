APP_NAME=Eagle
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# OpenWA Easy API. Start the local runtime with the same URL, key and session ID.
OPENWA_BASE_URL=http://127.0.0.1:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=eagle
OPENWA_FLAT_DELAY=60
OPENWA_WEBHOOK_SECRET=

# AI provider for the chatbot (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Live push for the Chats workspace. Set to "reverb" (with the block below and
# the reverb:start daemon running) for instant messages; any other value simply
# leaves the page on its polling fallback — nothing breaks.
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Laravel Reverb (WebSocket server). App credentials are arbitrary secrets you
# mint once. REVERB_HOST/PORT/SCHEME = how the BACKEND reaches the daemon
# (loopback is fine); REVERB_SERVER_* = what reverb:start binds to;
# VITE_REVERB_* = how the BROWSER connects (public hostname, baked at build).
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8085
REVERB_SCHEME=http
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8085

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5
