# Port the bridge listens on (matches docker-compose port mapping).
PORT=3000

# Shared secret Laravel sends as X-Api-Key on every request.
# Must equal WEBJS_API_KEY in the Laravel .env.
WEBJS_API_KEY=change-me-to-a-long-random-string

# Where whatsapp-web.js persists linked sessions (mount as a volume).
SESSION_PATH=/app/.wwebjs_auth
