# ---------------------------------------------------------------------------
# Eagleto Baileys Gateway — example environment
#
# Copy to .env and fill in. Never commit a real .env.
# Generate secrets with:  openssl rand -hex 32
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=3090

# Unique per running gateway container/process. Used in the Redis ownership
# lease so two nodes can never open the same WhatsApp session. If you run more
# than one replica, every replica needs a DIFFERENT value.
APP_NODE_ID=gateway-1

# ---------------------------------------------------------------------------
# Data stores
# ---------------------------------------------------------------------------
# POSTGRES_PASSWORD is read by the postgres container itself when it first
# initialises the database; DATABASE_URL is read by the gateway. They are two
# different consumers, so both are required and the password must match in
# each. docker compose refuses to start if POSTGRES_PASSWORD is unset.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://eagleto:change-me@postgres:5432/baileys_gateway?schema=public
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
# 32-byte hex key (64 hex characters). Encrypts WhatsApp auth state, proxy
# passwords and webhook secrets at rest. LOSING THIS MEANS EVERY WHATSAPP
# NUMBER MUST BE RE-LINKED. Back it up somewhere other than this server.
MASTER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Laravel -> Gateway authentication (inbound requests)
# ---------------------------------------------------------------------------
LARAVEL_API_KEY=
LARAVEL_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Gateway -> Laravel webhooks (outbound events)
# ---------------------------------------------------------------------------
LARAVEL_WEBHOOK_URL=https://rio.eagleto.com/webhooks/baileys
WEBHOOK_SIGNING_SECRET=
WEBHOOK_MAX_ATTEMPTS=10
WEBHOOK_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Baileys package selection
# ---------------------------------------------------------------------------
# Which Baileys implementation to run:
#   v6    = @whiskeysockets/baileys@6.7.23      (stable, default)
#   v7rc  = @whiskeysockets/baileys@7.0.0-rc13  (release candidate)
#   fork  = @itsukichan/baileys@7.3.2           (opt-in, see README security note)
#
# The fork is NOT installed by default because its preinstall script runs at
# install time. Install it deliberately with:  npm run use:baileys:fork
#
# WARNING: auth state written by one implementation is not guaranteed readable
# by another. The gateway records which package wrote each session and refuses
# to open a socket with a mismatched package unless you force it, which
# requires re-linking that number.
BAILEYS_PACKAGE=v6

# Allow a forced package switch on an existing session. Leave false in
# production — true will invalidate sessions and force QR re-scans.
BAILEYS_ALLOW_PACKAGE_SWITCH=false

# ---------------------------------------------------------------------------
# Connection behaviour
# ---------------------------------------------------------------------------
# How long a socket must stay open before the instance is promoted to READY.
# Prevents campaigns firing into a session that is still settling.
INSTANCE_STABILIZATION_SECONDS=60

MAX_RECONNECT_ATTEMPTS=8
RECONNECT_WINDOW_MINUTES=30
MAX_RECONNECT_DELAY_SECONDS=300

# Redis ownership lease
INSTANCE_LOCK_TTL_SECONDS=60
INSTANCE_LOCK_RENEW_SECONDS=20

# ---------------------------------------------------------------------------
# Human-like send behaviour (anti-ban)
# ---------------------------------------------------------------------------
# Show a "typing…" indicator before each text send: a think pause in
# [THINK_MIN, THINK_MAX] ms, then a compose window of ~MS_PER_CHAR per character,
# clamped to [MIN_TYPING, MAX_TYPING] ms. Set ENABLED=false to disable.
PRESENCE_SIMULATION_ENABLED=true
PRESENCE_MS_PER_CHAR=30
PRESENCE_MIN_TYPING_MS=900
PRESENCE_MAX_TYPING_MS=6000
PRESENCE_THINK_MIN_MS=500
PRESENCE_THINK_MAX_MS=1500

# Delayed read receipts: mark an inbound message read after a randomised 2–7 s
# (Gaussian) pause instead of instantly. OFF by default — enabling it makes the
# account send blue ticks it currently sends none of.
READ_RECEIPT_SIMULATION_ENABLED=false
READ_RECEIPT_MIN_MS=2000
READ_RECEIPT_MAX_MS=7000

# Group-action brake: minimum gap (ms) between actions targeting a group chat on
# one number, so group sends can never fire back-to-back. One-to-one sends are
# unaffected.
GROUP_ACTION_COOLDOWN_MS=15000

# Background entropy loop: every ENTROPY_MIN..MAX hours a live number performs
# one harmless "real phone" action (a presence blip / own-profile fetch) with NO
# outbound message. OFF by default.
ENTROPY_ENABLED=false
ENTROPY_MIN_HOURS=2
ENTROPY_MAX_HOURS=6

# Post-reconnect send ramp: for RECONNECT_RAMP_SECONDS after a number becomes
# sendable again, each send is held by a shrinking extra pause (starting near
# RECONNECT_RAMP_MAX_EXTRA_MS) so it eases back to full rate instead of blasting
# a queued batch the instant it returns. Set SECONDS=0 to disable.
RECONNECT_RAMP_SECONDS=60
RECONNECT_RAMP_MAX_EXTRA_MS=4000

# Session-health risk score (0 healthy … 100 critical). A gateway.health_warning
# webhook fires when a number crosses WARN, and again at CRITICAL. Crossing
# CRITICAL also halts that number's sends for CRITICAL_COOLDOWN_MINUTES (circuit
# breaker) — a burst of forbidden/replaced closes or decrypt failures stops
# feeding a degrading session more traffic.
SESSION_HEALTH_WARN_SCORE=50
SESSION_HEALTH_CRITICAL_SCORE=80
SESSION_HEALTH_CRITICAL_COOLDOWN_MINUTES=60

# ---------------------------------------------------------------------------
# Media
# ---------------------------------------------------------------------------
MAX_MEDIA_SIZE_MB=25
TEMP_MEDIA_RETENTION_MINUTES=60
MEDIA_STORAGE_PATH=/var/lib/eagleto-gateway/media
# Base URL the gateway hands to Laravel for downloading inbound media.
MEDIA_PUBLIC_BASE_URL=https://gateway.internal/media

# ---------------------------------------------------------------------------
# Logging and access control
# ---------------------------------------------------------------------------
LOG_LEVEL=info
# Comma-separated. Empty = no IP restriction (rely on the reverse proxy).
API_ALLOWED_IPS=
# Max clock skew accepted on a signed request, in seconds.
REQUEST_MAX_SKEW_SECONDS=300
